{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["esnext"],
    "types": ["node", "bun"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "skipLibCheck": true
  },
  "include": ["src"]
}
