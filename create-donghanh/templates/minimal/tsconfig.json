{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["esnext"],
    "types": ["@cloudflare/workers-types", "bun-types"],
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "jsxImportSource": "@donghanh/core"
  },
  "include": ["**/*.ts", "**/*.tsx"],
  "exclude": ["node_modules"]
}
